{
  "name": "@jwrighty/cedar-tokens",
  "version": "0.4.1",
  "description": "Cedar design tokens — a neutral DTCG source compiled to CSS custom properties and typed TS exports.",
  "license": "MIT",
  "author": "Jason Wright <jason.wrighty@gmail.com>",
  "homepage": "https://github.com/Jwrighty/cedar-ui/tree/main/packages/tokens#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jwrighty/cedar-ui.git",
    "directory": "packages/tokens"
  },
  "bugs": {
    "url": "https://github.com/Jwrighty/cedar-ui/issues"
  },
  "keywords": [
    "design-tokens",
    "design-system",
    "css-custom-properties",
    "style-dictionary",
    "dtcg",
    "theming",
    "cedar"
  ],
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./tokens.css": "./dist/tokens.css"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node build.js && tsc -p tsconfig.json",
    "test": "node --test test/*.test.mjs",
    "typecheck": "node build.js && tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "style-dictionary": "^5.5.0",
    "typescript": "^5.7.3"
  }
}
