{
  "semantic": {
    "color": {
      "text": {
        "default": { "$value": "{base.color.warm.900}", "$type": "color" },
        "muted": { "$value": "{base.color.warm.600}", "$type": "color" },
        "on-action": { "$value": "{base.color.white}", "$type": "color" },
        "accent": { "$value": "{base.color.teal.700}", "$type": "color" },
        "danger": { "$value": "{base.color.red.600}", "$type": "color" }
      },
      "surface": {
        "page": { "$value": "{base.color.warm.100}", "$type": "color" },
        "raised": { "$value": "{base.color.warm.50}", "$type": "color" },
        "sunken": { "$value": "{base.color.warm.200}", "$type": "color" }
      },
      "border": {
        "default": { "$value": "{base.color.warm.200}", "$type": "color" },
        "strong": { "$value": "{base.color.warm.300}", "$type": "color" }
      },
      "action": {
        "rest": { "$value": "{base.color.teal.700}", "$type": "color" },
        "hover": { "$value": "{base.color.teal.800}", "$type": "color" },
        "active": { "$value": "{base.color.teal.800}", "$type": "color" },
        "subtle": { "$value": "{base.color.teal.50}", "$type": "color" }
      },
      "danger": {
        "rest": { "$value": "{base.color.red.600}", "$type": "color" },
        "hover": { "$value": "{base.color.red.700}", "$type": "color" },
        "subtle": { "$value": "{base.color.red.50}", "$type": "color" }
      },
      "status": {
        "running": {
          "foreground": {
            "$value": "{base.color.amber.700}",
            "$type": "color"
          },
          "surface": { "$value": "{base.color.amber.50}", "$type": "color" },
          "border": { "$value": "{base.color.amber.500}", "$type": "color" }
        },
        "success": {
          "foreground": {
            "$value": "{base.color.green.700}",
            "$type": "color"
          },
          "surface": { "$value": "{base.color.green.50}", "$type": "color" },
          "border": { "$value": "{base.color.green.500}", "$type": "color" }
        },
        "error": {
          "foreground": { "$value": "{base.color.red.700}", "$type": "color" },
          "surface": { "$value": "{base.color.red.50}", "$type": "color" },
          "border": { "$value": "{base.color.red.500}", "$type": "color" }
        }
      },
      "chart": {
        "categorical": {
          "one": { "$value": "{base.color.teal.600}", "$type": "color" },
          "two": { "$value": "{base.color.blue.600}", "$type": "color" },
          "three": { "$value": "{base.color.violet.600}", "$type": "color" },
          "four": { "$value": "{base.color.amber.600}", "$type": "color" },
          "five": { "$value": "{base.color.red.600}", "$type": "color" },
          "six": { "$value": "{base.color.cyan.600}", "$type": "color" }
        },
        "axis": { "$value": "{base.color.warm.400}", "$type": "color" },
        "grid": { "$value": "{base.color.warm.200}", "$type": "color" }
      },
      "focus-ring": { "$value": "{base.color.teal.500}", "$type": "color" },
      "overlay-scrim": { "$value": "{base.color.scrim}", "$type": "color" }
    }
  }
}
