{
  "semantic": {
    "motion": {
      "duration": {
        "instant": {
          "$value": "{base.motion.duration.snap}",
          "$type": "duration"
        },
        "feedback": {
          "$value": "{base.motion.duration.fast}",
          "$type": "duration"
        },
        "settle": {
          "$value": "{base.motion.duration.base}",
          "$type": "duration"
        },
        "draw": { "$value": "{base.motion.duration.draw}", "$type": "duration" }
      },
      "easing": {
        "settle": {
          "$value": "{base.motion.easing.out}",
          "$type": "cubicBezier"
        },
        "enter": {
          "$value": "{base.motion.easing.snap}",
          "$type": "cubicBezier"
        },
        "emphasized": {
          "$value": "{base.motion.easing.decelerate}",
          "$type": "cubicBezier"
        },
        "playful": {
          "$value": "{base.motion.easing.overshoot}",
          "$type": "cubicBezier"
        }
      },
      "spring": {
        "overlay": {
          "stiffness": {
            "$value": "{base.motion.spring.gentle.stiffness}",
            "$type": "number"
          },
          "damping": {
            "$value": "{base.motion.spring.gentle.damping}",
            "$type": "number"
          },
          "mass": {
            "$value": "{base.motion.spring.gentle.mass}",
            "$type": "number"
          }
        },
        "live-update": {
          "stiffness": {
            "$value": "{base.motion.spring.snappy.stiffness}",
            "$type": "number"
          },
          "damping": {
            "$value": "{base.motion.spring.snappy.damping}",
            "$type": "number"
          },
          "mass": {
            "$value": "{base.motion.spring.snappy.mass}",
            "$type": "number"
          }
        }
      }
    }
  }
}
