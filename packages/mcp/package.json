{
  "name": "@jwrighty/cedar-mcp",
  "version": "0.2.2",
  "description": "MCP server exposing Cedar's agent-consumable component manifest and token reference.",
  "license": "MIT",
  "author": "Jason Wright <jason.wrighty@gmail.com>",
  "homepage": "https://github.com/Jwrighty/cedar-ui/tree/main/packages/mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jwrighty/cedar-ui.git",
    "directory": "packages/mcp"
  },
  "bugs": {
    "url": "https://github.com/Jwrighty/cedar-ui/issues"
  },
  "keywords": [
    "cedar",
    "design-system",
    "mcp",
    "model-context-protocol",
    "ai-agents"
  ],
  "type": "module",
  "bin": {
    "cedar-mcp": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/cli.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@jwrighty/cedar-react": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "vitest": "^4.1.9"
  }
}
