{
  "name": "@jwrighty/cedar-react",
  "version": "0.2.0",
  "description": "Cedar React components — accessible, themeable primitives built on React Aria, styled against @jwrighty/cedar-tokens.",
  "license": "MIT",
  "author": "Jason Wright <jason.wrighty@gmail.com>",
  "homepage": "https://github.com/Jwrighty/cedar-ui/tree/main/packages/react#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jwrighty/cedar-ui.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/Jwrighty/cedar-ui/issues"
  },
  "keywords": [
    "react",
    "design-system",
    "component-library",
    "react-aria",
    "accessible",
    "themeable",
    "ui-components",
    "cedar"
  ],
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./cedar.manifest.json": "./cedar.manifest.json",
    "./cedar.manifest.schema.json": "./cedar.manifest.schema.json",
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "cedar.manifest.json",
    "cedar.manifest.schema.json",
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json --emitDeclarationOnly",
    "prepack": "node ../../scripts/agent-surface.mjs generate",
    "dev": "vite build --watch & tsc -p tsconfig.build.json --emitDeclarationOnly --watch --preserveWatchOutput",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@jwrighty/cedar-tokens": "workspace:*",
    "react-aria-components": "^1.19.0"
  },
  "devDependencies": {
    "@storybook/react": "^8.6.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^29.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rollup-preserve-directives": "^1.1.3",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vitest": "^4.1.9",
    "vitest-axe": "^0.1.0"
  }
}
